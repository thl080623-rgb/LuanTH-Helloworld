<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="ir.module.category" id="module_category_idea_box">
            <field name="name">Idea Box</field>
            <field name="description">Quản lý phân quyền ứng dụng Hộp ý tưởng</field>
            <field name="sequence">10</field>
        </record>

        <record id="privilege_idea_box" model="res.groups.privilege">
            <field name="name">Quyền truy cập</field>
            <field name="category_id" ref="module_category_idea_box"/>
        </record>

        <record id="group_idea_box_user" model="res.groups">
            <field name="name">Nhân viên</field>
            <field name="privilege_id" ref="privilege_idea_box"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_idea_box_manager" model="res.groups">
            <field name="name">Quản lý</field>
            <field name="privilege_id" ref="privilege_idea_box"/>
            <field name="implied_ids" eval="[(4, ref('group_idea_box_user'))]"/>
        </record>
    </data>
</odoo>