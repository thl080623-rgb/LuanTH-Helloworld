<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_idea_box_all_read" model="ir.rule">
            <field name="name">Tất cả: Xem danh sách ý tưởng</field>
            <field name="model_id" ref="model_idea_box"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_idea_box_user_draft" model="ir.rule">
            <field name="name">Nhân viên: Quản lý ý tưởng nháp của mình</field>
            <field name="model_id" ref="model_idea_box"/>
            <field name="domain_force">[('create_uid', '=', user.id), ('state', 'in', ['draft', 'submitted'])]</field>
            <field name="groups" eval="[(4, ref('idea_box.group_idea_box_user'))]"/>
            <field name="perm_write">True</field>
            <field name="perm_unlink">False</field>
        </record>

        <record id="rule_idea_box_user_approved_read" model="ir.rule">
            <field name="name">Nhân viên: Xem ý tưởng được duyệt</field>
            <field name="model_id" ref="model_idea_box"/>
            <field name="domain_force">[('state', '=', 'approved')]</field>
            <field name="groups" eval="[(4, ref('idea_box.group_idea_box_user'))]"/>
            <field name="perm_write">False</field>
            <field name="perm_unlink">False</field>
        </record>

        <record id="rule_idea_box_manager" model="ir.rule">
            <field name="name">Quản lý: Quản lý toàn bộ ý tưởng</field>
            <field name="model_id" ref="model_idea_box"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('idea_box.group_idea_box_manager'))]"/>
        </record>
    </data>
</odoo>